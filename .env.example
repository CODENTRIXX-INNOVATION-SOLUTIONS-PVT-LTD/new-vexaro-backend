# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Local:   mongodb://localhost:27017/vexaro
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/vexaro
MONGODB_URI=mongodb://localhost:27017/vexaro

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=4a20f92db5478abfe8f4c2c5896a798a1a3641b9c9f80de9f417f7324c442cf8
JWT_EXPIRES_IN=7d

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@vexarocouriersolutions.com
SMTP_PASS=your_app_password
CONTACT_TO_EMAIL=info@vexarocouriersolutions.com
CONTACT_FROM_EMAIL=no-reply@vexaro.com
CONTACT_RATE_LIMIT_WINDOW_MINUTES=15
CONTACT_RATE_LIMIT_MAX=10
EMAIL_FROM=info@vexarocouriersolutions.com

# ─── App ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:4200
INVITE_TOKEN_EXPIRES_HOURS=48
RESET_TOKEN_EXPIRES_HOURS=2

# ─── Razorpay ───────────────────────────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
# Use rzp_test_* for test mode, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
# Set in Razorpay Dashboard -> Webhooks -> Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
# Max wallet topup per transaction in INR (default: ₹1,00,000)
RAZORPAY_MAX_TOPUP_AMOUNT=100000

# ─── Sentry (optional — error monitoring) ────────────────────────────────────
# Sign up free at https://sentry.io, create a Node.js project, copy the DSN here.
# Leave blank to disable Sentry in development.
SENTRY_DSN=

# ─── Velocity Shipping ────────────────────────────────────────────────────────
# Get credentials from your Velocity dashboard → Settings → API
# Base URL: use https://app.velocity.in/ for production
#           use https://staging.velocity.in/ for sandbox/testing
# The default https://shazam.velocity.in/ is an internal hostname that may not
# resolve from outside their network — use the correct public URL below.
VELOCITY_BASE_URL=https://app.velocity.in/
VELOCITY_USERNAME=your_velocity_email@example.com
VELOCITY_PASSWORD=your_velocity_password
VELOCITY_WEBHOOK_SECRET=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true

# ─── Redis ────────────────────────────────────────────────────────────────────
# Set REDIS_ENABLED=false to disable caching entirely (e.g. in CI)
REDIS_URL=redis://127.0.0.1:6379
REDIS_ENABLED=true
